{
  "//": "Design spec for the conformance demo. In production, generate `expect` from Figma via the figma.fileKey + mapping (see DESIGN-CONFORMANCE.md) — here the values are inline.",
  "route": "/conformance",
  "tolerances": { "color": 2.0, "px": 1.5 },
  "components": [
    {
      "key": "cta",
      "selector": "[data-fig=cta]",
      "expect": { "backgroundColor": "#4f46e5", "color": "#ffffff", "fontSize": 16, "fontWeight": 600, "paddingTop": 14, "borderRadius": 12, "height": 48 }
    },
    {
      "key": "card",
      "selector": "[data-fig=card]",
      "expect": { "backgroundColor": "#ffffff", "paddingTop": 16, "paddingLeft": 16, "borderRadius": 16, "gap": 12 }
    },
    {
      "key": "badge",
      "selector": "[data-fig=badge]",
      "expect": { "backgroundColor": "#10b981", "borderRadius": 999, "fontSize": 11 }
    }
  ]
}
